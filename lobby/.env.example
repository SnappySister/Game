# 环境变量示例(无真实密钥)。复制为 .env 并填真实值，后者已被 .gitignore 忽略。
# 服务器部署时优先用 pm2 注入环境变量，.env 仅本地开发用。

# 服务端口
PORT=3456

# 数据库文件路径
DB_PATH=./lobby/data/game.db

# session 密钥(随机长字符串，用于签发登录 token)
SESSION_SECRET=_请替换为随机长字符串_

# session 有效期(天)
SESSION_TTL_DAYS=7

# bcrypt 加盐轮数(10-12，越大越慢越安全)
BCRYPT_ROUNDS=10

# 断线重连宽限期(毫秒)
RECONNECT_GRACE_MS=120000
